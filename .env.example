# =============================================================================
# 环境变量配置模板
# =============================================================================
# 
# 使用方法：
#   1. 复制此文件为 .env ：  cp .env.example .env
#   2. 填写真实的密钥值
#   3. .env 已被 .gitignore 忽略，不会提交到 Git
#
# 云部署（Streamlit Cloud / 其他平台）：
#   在平台的环境变量设置中按同样名称配置即可
# =============================================================================

# ---------------------------------------------------------------------------
# 数据库配置（MySQL）
# ---------------------------------------------------------------------------
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password_here
DB_NAME=ai_stock

# ---------------------------------------------------------------------------
# AI 模型配置
# ---------------------------------------------------------------------------
# 火山引擎 ARK: https://console.volcengine.com/ark
AI_MODEL=ep-xxxxxxxxxxxx-xxxxx
AI_API_BASE=https://ark.cn-beijing.volces.com/api/v3
AI_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# 日志级别（可选，默认 INFO）
# ---------------------------------------------------------------------------
# LOG_LEVEL=DEBUG
